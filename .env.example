# OmniBrain V2 — Environment Variables
#
# Minimal local env. All secrets stored in Redis via the bridge.
# Run: python3 seed_credentials.py  (one time, populates Redis)

# Redis connection (required)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# Bridge server (optional, for VPS registration)
BRIDGE_URL=http://localhost:8765
BRIDGE_API_KEY=

# Role (set per-instance: master / worker-1 / worker-2 / worker-3)
# Not needed if running via start.sh which passes it as an arg
# ROLE=master
