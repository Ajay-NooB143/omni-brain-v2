# ─────────────────────────────────────────────────────────────────────────
mt5_cache/
*.fxt
*.hst
*.raw
account_info.json
broker_credentials.json

# ─────────────────────────────────────────────────────────────────────────
# DOCKER
# ─────────────────────────────────────────────────────────────────────────
.dockerignore
docker-compose.override.yml
*.dockerfile

# ─────────────────────────────────────────────────────────────────────────
