# ─────────────────────────────────────────────────────────────────────────
pm2.json
pm2-error.log
pm2-out.log
logs/*.log
ecosystem.json

# ─────────────────────────────────────────────────────────────────────────
# DATABASE & CACHE
# ─────────────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
redis/
redis_dump.rdb
dump.rdb

# ─────────────────────────────────────────────────────────────────────────
# OS FILES
# ─────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.Spotlight-V100
.Trashes
ehthumbs.db
$RECYCLE.BIN/

# ─────────────────────────────────────────────────────────────────────────
