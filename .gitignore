# ─────────────────────────────────────────────────────────────────────────
.git/
.gitattributes
.gitkeep
*.patch
*.diff

# ─────────────────────────────────────────────────────────────────────────
# TEMPORARY & BUILD FILES
# ─────────────────────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.swp
*~
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
.tox/
dist/
build/
*.egg-info/
.mypy_cache/
.dmypy.json
dmypy.json

# ─────────────────────────────────────────────────────────────────────────
# LOCAL CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/workspace.xml
.idea/vcs.xml
*.local
local_*
private/

# ─────────────────────────────────────────────────────────────────────────
# BACKUP & ARCHIVE
# ─────────────────────────────────────────────────────────────────────────
*.zip
*.tar
*.tar.gz
*.rar
*.bak
*-backup/

# ─────────────────────────────────────────────────────────────────────────
# TRADING / FINANCIAL DATA (DO NOT COMMIT)
# ─────────────────────────────────────────────────────────────────────────
data/datasets/*.csv
trades.json
signals.json
backtest_results/
historical_data/

# ─────────────────────────────────────────────────────────────────────────
