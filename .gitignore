# ═══════════════════════════════════════════════════════════════════════════
# OMNI BRAIN V2 .gitignore
# Prevents committing secrets, dependencies, build artifacts
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────
# ENVIRONMENT & SECRETS (CRITICAL)
# ─────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
*.pem
*.key
*.p8
secret_*
credentials.json
config.secret.json

# ─────────────────────────────────────────────────────────────────────────
# PYTHON VIRTUAL ENVIRONMENTS
# ─────────────────────────────────────────────────────────────────────────
venv/
env/
ENV/
.venv
.env
pip-log.txt
pip-delete-this-directory.txt
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ─────────────────────────────────────────────────────────────────────────
# NODE / NEXT.JS
# ─────────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log
yarn-error.log
.next/
out/
.cache/
.vercel
.turbo
.env.local
.env.development.local
.env.test.local
.env.production.local

