# ─────────────────────────────────────────────────────────────────────────
.github/workflows/generated/
.travis/
.circleci/
artifacts/
reports/

# ─────────────────────────────────────────────────────────────────────────
# PROJECT SPECIFIC
# ─────────────────────────────────────────────────────────────────────────
# OMNI BRAIN V2
bridge_server_logs/
worker_logs/
health_check_reports/

